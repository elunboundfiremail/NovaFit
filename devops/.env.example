# Configuracion de entorno para NovaFit
# Copiar este archivo a .env y ajustar valores si es necesario

# PostgreSQL - Base de datos principal
POSTGRES_DB=novafit_db
POSTGRES_USER=novafit_user
POSTGRES_PASSWORD=Upds123
POSTGRES_PORT=5432

# Keycloak - Servidor de autenticacion
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=Upds123
KEYCLOAK_PORT=8080
KEYCLOAK_DB=keycloak_db
KEYCLOAK_DB_USER=keycloak_user
KEYCLOAK_DB_PASSWORD=Upds123

# API Backend
API_PORT=5000
API_ENVIRONMENT=Development

# Configuracion de red
NETWORK_NAME=novafit_network

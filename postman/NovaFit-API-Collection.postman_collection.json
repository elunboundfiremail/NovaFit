            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombres\": \"Juan Carlos\",\n  \"apellidoPaterno\": \"Perez\",\n  \"apellidoMaterno\": \"Lopez\",\n  \"activo\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/clientes/:id",
